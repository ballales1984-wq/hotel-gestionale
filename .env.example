# ─── Environment Variables ────────────────────────────────────────────────
# Copia questo file in .env e personalizza i valori
# NON committare .env nel repository

# Database
POSTGRES_PASSWORD=hotel_secure_2025_change_me
REDIS_PASSWORD=redis_secure_2025_change_me

# Backend
SECRET_KEY=change_me_in_production_must_be_32_chars_minimum
ENVIRONMENT=development
LOG_LEVEL=info

# Encryption (Fernet key per dati sensibili)
ENCRYPTION_KEY=  # Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Superset BI
SUPERSET_SECRET_KEY=superset_secret_key_change_in_prod_32chars

# Frontend target (development | production)
FRONTEND_TARGET=development

# Optional: Email SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Optional: Slack Webhook for Alertmanager
# Creare un Incoming Webhook in Slack: https://myworkspace.slack.com/apps/A0F7XDUAZ-incoming-webhooks
SLACK_WEBHOOK_URL=
