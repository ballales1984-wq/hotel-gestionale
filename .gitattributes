# .gitattributes — Normalizzazione line endings per piattaforme ibride (Windows/Unix)
# Imposta default: testo con auto-normalizzazione (LF in repo, checkout dipende da OS)
* text=auto

# Batch Windows (.bat, .cmd) → CRLF su checkout, LF in repo
*.bat text eol=crlf
*.cmd text eol=crlf

# Script Unix / Codice sorgente → LF sempre
*.py text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.ksh text eol=lf
*.csh text eol=lf
*.fish text eol=lf

# Configurazione e data files → LF
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.env text eol=lf
*.env.example text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.csv text eol=lf
*.sql text eol=lf
*.dockerignore text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Frontend source files → LF
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.less text eol=lf
*.html text eol=lf
*.htm text eol=lf

# Dockerfile e compose → LF
Dockerfile text eol=lf
docker-compose*.yml text eol=lf
docker-compose*.yaml text eol=lf

# Template e documentazione → LF
*.jinja text eol=lf
*.j2 text eol=lf
*.rst text eol=lf

